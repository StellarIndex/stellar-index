{
  "name": "@stellarindex/explorer",
  "version": "0.0.0",
  "private": true,
  "description": "Public showcase site + explorer for the Stellar Index API (stellarindex.io).",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "ESLINT_USE_FLAT_CONFIG=false eslint . --ext .js,.jsx,.ts,.tsx --ignore-pattern .next/ --ignore-pattern out/ --ignore-pattern next-env.d.ts",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "generate:api": "openapi-typescript ../../openapi/stellar-index.v1.yaml -o src/api/types.ts",
    "prebuild": "mkdir -p public/openapi && cp ../../openapi/stellar-index.v1.yaml public/openapi/stellar-index.v1.yaml"
  },
  "dependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "@tanstack/react-query": "^5.101.2",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "lightweight-charts": "^5.2.0",
    "lucide-react": "^1.23.0",
    "next": "16.2.9",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "satori": "^0.12.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "workers-og": "^0.0.27",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.5.2",
    "eslint": "^9.15.0",
    "eslint-config-next": "15.0.4",
    "openapi-typescript": "^7.4.4",
    "postcss": "^8.5.16",
    "prettier": "^3.3.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^3.4.15",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "overrides": {
      "postcss@<8.5.10": ">=8.5.10",
      "js-yaml@<4.2.0": ">=4.2.0"
    }
  }
}
