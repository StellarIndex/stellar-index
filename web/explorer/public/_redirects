/router                        /aggregators/  301
/router/                       /aggregators/  301
/routers                       /aggregators/  301
/routers/                      /aggregators/  301
/aggregator                    /aggregators/  301
/aggregator/                   /aggregators/  301
/yield                         /aggregators/  301
