# only a route prefix (`/research/adr/[id]/page.tsx`,
# `/lending/[pool]/page.tsx`) without an index page of its own.
# Bounce them up one level to the canonical entry that DOES list
# everything in the category. The 404 audit on 2026-05-08 caught
# these as the only remaining bare-category dead-ends.
/research/adr            /research/  301
/research/adr/           /research/  301
/research/architecture   /research/  301
/research/architecture/  /research/  301
/research/discovery      /research/  301
/research/discovery/     /research/  301
/research/operations     /research/  301
/research/operations/    /research/  301

# Same problem for lending: pools are keyed by contract address
# (G-strkey), so the protocol name "blend" тАФ even though it's
# the only lending protocol we cover today тАФ wasn't routable.
# Bounce to the lending listing.
/lending/blend           /lending/   301
/lending/blend/          /lending/   301

# /favicon.ico тЖТ /icon.svg. Next 15's `src/app/icon.svg` metadata
# route serves the SVG and emits the right <link rel="icon"> in the
# rendered HTML, so modern browsers find the favicon via that link
# tag and never ask for /favicon.ico. But many crawlers, RSS
# readers, link-preview cards, and browser address-bar fallbacks
# STILL hit /favicon.ico unconditionally тАФ without this rule every
# one of those requests was a noisy 404. SVG favicons render in
# Chrome 80+, Firefox 80+, Safari 15+, Edge тАФ essentially every
# client shipping for 4+ years. Older clients that wouldn't render
# the SVG would have rendered nothing here anyway (no prior .ico),
# so this is strictly an improvement.
/favicon.ico             /icon.svg   301
