# Cloudflare Pages reads this file from the build output and applies
# the rules to every response. Netlify uses the same format. For
# Vercel, translate manually to `vercel.json` headers; the
# operator runbook (docs/operations/showcase-deployment.md)
# flags this as a per-host translation step.
#
# Security philosophy: defence-in-depth on a static site that loads
# nothing from third parties at runtime. Every request the showcase
# makes goes to api.ratesengine.net (set via NEXT_PUBLIC_API_BASE_URL
# at build time); everything else is local self-references.

/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: accelerometer=(), camera=(), geolocation=(), microphone=(), payment=(), usb=()
  # HSTS — pin HTTPS for one year, including subdomains
  # (api.ratesengine.net, status.ratesengine.net,
  # docs.ratesengine.net are all HTTPS-only at the edge so the
  # includeSubDomains directive is safe). `preload` is
  # intentionally OMITTED until the operator has submitted the
  # apex to https://hstspreload.org/ — preload is irrevocable
  # once browsers ship it, so we ratchet up in two steps.
  Strict-Transport-Security: max-age=31536000; includeSubDomains
  # CSP — restrictive but functional. 'unsafe-inline' is required
  # for Next.js static-export bootstrap scripts and Tailwind inline
  # styles; revisit if Next stops emitting them. connect-src lists
  # the API origin so fetch() works; localhost added so a built
  # bundle can be served against a local dev API without a
  # CSP-violation flood. frame-ancestors 'none' is the modern
  # equivalent of X-Frame-Options DENY (browsers prefer the CSP
  # form when both are set).
  Content-Security-Policy: default-src 'self'; connect-src 'self' https://api.ratesengine.net http://localhost:3000; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self' data:; object-src 'none'; base-uri 'self'; frame-ancestors 'none'; form-action 'self'

# Fingerprinted Next.js assets — far-future cache. CF Pages already
# does this by default but the explicit header doubles as
# documentation; Netlify needs it.
/_next/static/*
  Cache-Control: public, max-age=31536000, immutable

# /embed/* widgets are explicitly designed to be iframe'd into
# customer sites — that's the entire product surface (see /widgets).
# The /* rule above sets `frame-ancestors 'none'` and
# `X-Frame-Options: DENY`, which would block every customer iframe.
# Override with a permissive frame-ancestors here. CSP otherwise
# stays as restrictive as the parent rule (modulo the
# frame-ancestors swap).
#
# X-Frame-Options: DENY from the parent rule is harmless because
# modern browsers ignore X-Frame-Options whenever a CSP
# frame-ancestors directive is present (per MDN's
# X-Frame-Options docs). We set it to ALLOWALL here so even
# legacy browsers that pre-date CSP frame-ancestors don't
# refuse to render the iframe.
/embed/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: ALLOWALL
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: accelerometer=(), camera=(), geolocation=(), microphone=(), payment=(), usb=()
  # HSTS still applies to /embed/* — _headers rules are full
  # replacement (NOT merged) per CF Pages docs, so we repeat the
  # parent's HSTS directive here. Same lifetime / same scope.
  Strict-Transport-Security: max-age=31536000; includeSubDomains
  Content-Security-Policy: default-src 'self'; connect-src 'self' https://api.ratesengine.net http://localhost:3000; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self' data:; object-src 'none'; base-uri 'self'; frame-ancestors *; form-action 'self'
