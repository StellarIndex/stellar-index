# Go build artefacts
/bin/
/dist/
*.test
*.out
coverage.txt
coverage.html
# Stray binaries built without -o bin/ (prevent accidental root-level commits).
/ratesengine-indexer
/ratesengine-aggregator
/ratesengine-api
/ratesengine-ops
/ratesengine-migrate

# Go tool caches
/.gocache/

# Editors / OS
.DS_Store
.idea/
.vscode/
*.swp
*~

# Local environment / secrets — NEVER commit any of these.
.env
.env.*
!.env.example
*.env
credentials*.json
service-account*.json
*.key
*.pem
*.p12
*.pfx
*.jks
*.keystore

# Local runtime state
/bucket-data/
/galexie-data/
/postgres-data/
/redis-data/
/minio-data/
/stellar-core-data/
/tmp/
*.log

# Deployment overrides (local-only tweaks)
/configs/local.yaml
/configs/*.secret.yaml
/deploy/docker-compose/.env

# Ansible vault-encrypted secrets — safe in theory but conservative:
# never commit until we have a team-wide vault key management plan.
/configs/ansible/inventory/*.secrets.yml
/configs/ansible/inventory/*.secrets.yaml
/configs/ansible/vault-password.txt

# Real per-region inventories carry public IPs, drive serials, SSH
# pubkeys, etc. — operationally sensitive even if not strictly
# secret. Operators copy r*.example.yml → r*.yml locally; the .yml
# stays local-only. The .example template is the public reference.
/configs/ansible/inventory/r*.yml
!/configs/ansible/inventory/r*.example.yml

# Docs build output
/docs/_site/
/docs/_build/
/docs/reference/api/generated/
/docs/reference/config/generated/
/docs/reference/metrics/generated/

# Test artefacts
/test/load/reports/*
!/test/load/reports/README.md
/test/chaos/reports/*
!/test/chaos/reports/.gitkeep
# Launch-cut + monthly chaos runs are committed per
# docs/operations/chaos-wave1-runbook.md §"Recording the run".
!/test/chaos/reports/2026-*/
!/test/chaos/reports/2027-*/
!/test/chaos/reports/2028-*/
!/test/chaos/reports/2029-*/
/test/integration/.testcache/

# Discovery scratch — do NOT port to implementation repo
/.discovery-repos/

# Agent session state — local only
/.claude/
/docs/reference/api/postman-collection.json
/.wrangler/
