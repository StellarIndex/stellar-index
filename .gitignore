# Go build artefacts
/bin/
/dist/
*.test
*.out
coverage.txt
coverage.html
# Stray binaries built without -o bin/ (prevent accidental root-level commits).
/stellarindex-indexer
/stellarindex-aggregator
/stellarindex-api
/stellarindex-ops
/stellarindex-migrate

# Go tool caches
/.gocache/

# Editors / OS
.DS_Store
.idea/
.vscode/
*.swp
*~

# Local environment / secrets — NEVER commit any of these.
.env
.env.*
!.env.example
*.env
credentials*.json
service-account*.json
*.key
*.pem
*.p12
*.pfx
*.jks
*.keystore
# Defence-in-depth glob for ansible-style secrets files
# (F-1207, audit-2026-05-12): the inventory-path-scoped rules below
# already cover the canonical path, but a stray *.secrets.yml outside
# configs/ansible/inventory/ would not be caught without this.
*.secrets.yml
*.secrets.yaml

# Local runtime state
/bucket-data/
/galexie-data/
/postgres-data/
/redis-data/
/minio-data/
/stellar-core-data/
/tmp/
*.log

# Deployment overrides (local-only tweaks)
/configs/local.yaml
/configs/*.secret.yaml
/deploy/docker-compose/.env

# Ansible vault-encrypted secrets — safe in theory but conservative:
# never commit until we have a team-wide vault key management plan.
/configs/ansible/inventory/*.secrets.yml
/configs/ansible/inventory/*.secrets.yaml
/configs/ansible/vault-password.txt

# Real per-region inventories carry public IPs, drive serials, SSH
# pubkeys, etc. — operationally sensitive even if not strictly
# secret. Operators copy r*.example.yml → r*.yml locally; the .yml
# stays local-only. The .example template is the public reference.
/configs/ansible/inventory/r*.yml
!/configs/ansible/inventory/r*.example.yml

# Docs build output
/docs/_site/
/docs/_build/
/docs/reference/api/generated/
/docs/reference/config/generated/
/docs/reference/metrics/generated/

# Test artefacts
/test/load/reports/*
!/test/load/reports/README.md
# Acceptance-criteria evidence runs are committed (deliverable evidence
# pack; docs/architecture/deliverable-evidence.md cites them by path).
!/test/load/reports/2026-*/
!/test/load/reports/2027-*/
!/test/load/reports/2028-*/
!/test/load/reports/2029-*/
/test/chaos/reports/*
!/test/chaos/reports/.gitkeep
# Launch-cut + monthly chaos runs are committed per
# docs/operations/chaos-wave1-runbook.md §"Recording the run".
!/test/chaos/reports/2026-*/
!/test/chaos/reports/2027-*/
!/test/chaos/reports/2028-*/
!/test/chaos/reports/2029-*/
/test/integration/.testcache/

# Discovery scratch — do NOT port to implementation repo
/.discovery-repos/

# Agent session state — local only
/.claude/
/docs/reference/api/postman-collection.json
/.wrangler/

# GCP / BigQuery service-account keys — credentials, NEVER commit
stellar-index-data-validation-*.json
*.iam.gserviceaccount.com.json
gcp-key*.json

# local credentials + stray build artifacts — never commit
*-data-validation-*.json
# Stray root-level binaries (a `go build ./cmd/...` without -o bin/ drops
# the binary at the repo root). The cmd/ source dirs are re-allowed below.
/stellarindex-*
!/cmd/stellarindex-*

# Internal archive: proposal/RFP sources, historical audit working dirs, and
# the early-stage discovery notes. Kept on disk for reference, never published.
/docs/archive/
