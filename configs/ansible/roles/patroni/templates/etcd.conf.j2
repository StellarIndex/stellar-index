{# Render-time config — managed by ansible (patroni role). #}
{# `etcd` reads this from /etc/default/etcd via the systemd unit's #}
{# EnvironmentFile= directive. #}
ETCD_NAME="{{ inventory_hostname }}"
ETCD_DATA_DIR="{{ etcd_data_dir }}"

ETCD_LISTEN_PEER_URLS="http://{{ ansible_host }}:{{ etcd_peer_port }}"
ETCD_LISTEN_CLIENT_URLS="http://{{ ansible_host }}:{{ etcd_client_port }},http://127.0.0.1:{{ etcd_client_port }}"

ETCD_INITIAL_ADVERTISE_PEER_URLS="http://{{ ansible_host }}:{{ etcd_peer_port }}"
ETCD_ADVERTISE_CLIENT_URLS="http://{{ ansible_host }}:{{ etcd_client_port }}"

ETCD_INITIAL_CLUSTER_TOKEN="{{ etcd_cluster_token }}"
ETCD_INITIAL_CLUSTER="{% for host in groups['postgres_cluster'] %}{{ host }}=http://{{ hostvars[host].ansible_host }}:{{ etcd_peer_port }}{% if not loop.last %},{% endif %}{% endfor %}"
ETCD_INITIAL_CLUSTER_STATE="new"

ETCD_HEARTBEAT_INTERVAL="{{ etcd_heartbeat_interval }}"
ETCD_ELECTION_TIMEOUT="{{ etcd_election_timeout }}"

# Logging
ETCD_LOGGER="zap"
ETCD_LOG_LEVEL="info"
