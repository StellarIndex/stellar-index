{#   ~vwap:* ~confidence:* ~freeze:* ~div:* ~health:* &closed-bucket-* #}
{# user re_api        on >$pass_api        -@all +@read +@write +@pubsub -@admin -@dangerous \ #}
{#   ~vwap:* ~confidence:* ~freeze:* ~div:* ~ratelimit:* ~signup-ip:* \ #}
{#   ~toml:* ~meta:* ~price:* ~apikey:* ~oracle:* ~subscriber:* &closed-bucket-* &stream-* #}
{# user re_indexer    on >$pass_indexer    -@all +@read +@write -@admin -@dangerous \ #}
{#   ~health:* #}
