{# Render-time — managed by ansible (haproxy role). Don't edit. #}
{# Validated by `haproxy -c -f` before reload. #}

global
    log stdout format raw local0
    maxconn {{ haproxy_max_conn }}
    user haproxy
    group haproxy
    daemon
    stats socket /run/haproxy/admin.sock mode 660 level admin expose-fd listeners
    # SSL hardening — modern intermediate per Mozilla.
    ssl-default-bind-options ssl-min-ver TLSv1.2 no-tls-tickets
    ssl-default-bind-ciphers ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384:ECDHE-ECDSA-CHACHA20-POLY1305:ECDHE-RSA-CHACHA20-POLY1305:DHE-RSA-AES128-GCM-SHA256:DHE-RSA-AES256-GCM-SHA384

defaults
    mode http
    log global
    option httplog
    option dontlognull
    option forwardfor
    option redispatch
    timeout connect 5s
    timeout client  60s
    timeout server  60s
    retries 3
    errorfile 400 /etc/haproxy/errors/400.http
    errorfile 403 /etc/haproxy/errors/403.http
    errorfile 408 /etc/haproxy/errors/408.http
    errorfile 500 /etc/haproxy/errors/500.http
    errorfile 502 /etc/haproxy/errors/502.http
    errorfile 503 /etc/haproxy/errors/503.http
    errorfile 504 /etc/haproxy/errors/504.http

frontend api_https
    bind *:443 ssl crt {{ haproxy_tls_cert_dir }}/{{ haproxy_tls_cert_filename }}
    bind *:80
    redirect scheme https code 301 if !{ ssl_fc }
    # Strict-Transport-Security: 1 year, include subdomains.
    http-response set-header Strict-Transport-Security "max-age=31536000; includeSubDomains"
    default_backend api_pool

backend api_pool
    balance roundrobin
    # Health-check via /v1/readyz — the deep ready probe; passes
    # only when Timescale + Redis are both reachable per
    # internal/api/v1/server.go. /v1/healthz would only confirm
    # process-alive (insufficient for routing).
    option httpchk GET {{ haproxy_health_check_path }}
    http-check expect status 200
    # 5s interval × 3 fails before drain × 2 successes before
    # re-add → 15s detection window, 10s slowstart prevents cold
    # pod from getting hammered after recovery.
    default-server inter 5s fall 3 rise 2 slowstart 10s
{% for h in groups['ratesengine_api'] %}
    server {{ h }} {{ hostvars[h].ansible_host }}:{{ ratesengine_api_port }} check
{% endfor %}

# Stats endpoint, loopback-only. Operators SSH-tunnel for remote
# access; never expose 8404 publicly.
frontend stats
    bind {{ haproxy_stats_listen }}
    stats enable
    stats uri /
    stats refresh 10s
{% if haproxy_prometheus_endpoint %}
    # HAProxy 2.4+ built-in Prometheus exporter.
    http-request use-service prometheus-exporter if { path /metrics }
{% endif %}
