{# Render-time — managed by ansible (haproxy role). Don't edit. #}

# chk_haproxy fires if haproxy isn't running, demoting this host
# from MASTER even if the network is otherwise healthy.
vrrp_script chk_haproxy {
    script "/usr/bin/pgrep haproxy"
    interval 2
    fall 2
    rise 2
}

vrrp_instance VI_API {
    state {{ keepalived_initial_state }}
    interface {{ keepalived_iface }}
    virtual_router_id {{ keepalived_vrid }}
    priority {{ keepalived_priority }}
    advert_int 1

    # auth_pass is silently truncated past 8 bytes by keepalived;
    # vault-supplied; preflight warns if longer than 8 chars.
    authentication {
        auth_type PASS
        auth_pass {{ keepalived_vrrp_password }}
    }

    virtual_ipaddress {
        {{ haproxy_vip }}/{{ keepalived_vip_prefix_length }}
    }

    track_script {
        chk_haproxy
    }
}
