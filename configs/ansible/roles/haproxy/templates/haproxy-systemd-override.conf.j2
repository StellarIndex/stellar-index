{# Render-time — managed by ansible (haproxy role). #}
{# Hardening drop-in. The distro ships its own haproxy.service unit; #}
{# we add this drop-in so apt upgrades can update the canonical unit #}
{# without losing our hardening. #}

[Service]
# Hardening
ProtectSystem=full
ProtectHome=yes
PrivateTmp=yes
NoNewPrivileges=yes

# File-descriptor limit raised for high connection counts.
# HAProxy's `maxconn` × 2 is the rule of thumb (each conn = 2 FDs:
# client + backend). We match haproxy_max_conn × 2 plus 10% slack.
LimitNOFILE={{ (haproxy_max_conn | int * 2.1) | int }}

# Restart policy — preserve service availability on transient
# crashes. Reload-on-config-change uses `systemctl reload` (not
# restart), which is zero-drop.
Restart=on-failure
RestartSec=5s
