{# Render-time — managed by ansible (prometheus role). Don't edit. #}
{# Validated by `amtool check-config` before reload. #}

global:
  resolve_timeout: 5m
{% if alertmanager_slack_webhook_url %}
  slack_api_url: {{ alertmanager_slack_webhook_url }}
{% endif %}

route:
  # Default receiver when no per-severity match — set conservatively
  # to PagerDuty so unrouted alerts still land somewhere visible.
  receiver: 'pagerduty-default'
  group_by: ['alertname', 'severity']
  group_wait: 30s
  group_interval: 5m
  repeat_interval: 12h
  routes:
    - matchers:
        - severity = "critical"
      receiver: 'pagerduty-default'
    - matchers:
        - severity = "warning"
      receiver: 'chat-fanout'
    - matchers:
        - severity = "info"
      receiver: 'chat-fanout'

receivers:
  - name: 'pagerduty-default'
{% if alertmanager_pagerduty_key %}
    pagerduty_configs:
      - service_key: {{ alertmanager_pagerduty_key }}
        send_resolved: true
{% else %}
    # No pagerduty_key set — alerts accumulate in the AlertManager
    # UI but don't fan out. Set alertmanager_pagerduty_key in vault
    # to enable PagerDuty integration.
{% endif %}

  # chat-fanout — Slack + Discord parallel fanout. Either, both,
  # or neither may be wired; an empty webhook degrades silently to
  # "no receiver of that flavour". The proposal commits to both
  # ("integrated into discord/slack") so this template ships them
  # as peers rather than picking a primary.
  - name: 'chat-fanout'
{% if alertmanager_slack_webhook_url %}
    slack_configs:
      - channel: {{ alertmanager_slack_channel }}
        send_resolved: true
        title: '{{ "{{" }} .GroupLabels.alertname {{ "}}" }}'
        text: |
          {{ "{{" }} range .Alerts {{ "}}" }}
          *{{ "{{" }} .Labels.severity | toUpper {{ "}}" }}* {{ "{{" }} .Annotations.summary {{ "}}" }}
          {{ "{{" }} .Annotations.description {{ "}}" }}
          {{ "{{" }} if .Annotations.runbook_url {{ "}}" }}runbook: {{ "{{" }} .Annotations.runbook_url {{ "}}" }}{{ "{{" }} end {{ "}}" }}
          {{ "{{" }} end {{ "}}" }}
{% endif %}
{% if alertmanager_discord_webhook_url %}
    # Discord webhooks accept the same JSON envelope as Slack's
    # "incoming-webhook" path when AlertManager's discord_configs
    # is used (added in AM 0.27). Title + body come from the same
    # group/alert templating as Slack so operators see consistent
    # text in either channel.
    discord_configs:
      - webhook_url: {{ alertmanager_discord_webhook_url }}
        send_resolved: true
        title: '{{ "{{" }} .GroupLabels.alertname {{ "}}" }}'
        message: |
          {{ "{{" }} range .Alerts {{ "}}" }}
          **{{ "{{" }} .Labels.severity | toUpper {{ "}}" }}** {{ "{{" }} .Annotations.summary {{ "}}" }}
          {{ "{{" }} .Annotations.description {{ "}}" }}
          {{ "{{" }} if .Annotations.runbook_url {{ "}}" }}runbook: {{ "{{" }} .Annotations.runbook_url {{ "}}" }}{{ "{{" }} end {{ "}}" }}
          {{ "{{" }} end {{ "}}" }}
{% endif %}
{% if not alertmanager_slack_webhook_url and not alertmanager_discord_webhook_url %}
    # Neither slack_webhook_url nor discord_webhook_url set — no
    # fanout. Alerts accumulate in the AlertManager UI but don't
    # reach any chat channel. Set at least one webhook in vault.
{% endif %}

inhibit_rules:
  # If a critical-severity alert fires for the same service, mute
  # warnings + info for that alertname to avoid stacking.
  - source_matchers:
      - severity = "critical"
    target_matchers:
      - severity =~ "warning|info"
    equal: ['alertname', 'service']
