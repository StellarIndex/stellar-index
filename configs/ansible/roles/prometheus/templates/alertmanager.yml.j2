{# Render-time — managed by ansible (prometheus role). Don't edit. #}
{# Validated by `amtool check-config` before reload. #}

global:
  resolve_timeout: 5m
{% if alertmanager_slack_webhook_url %}
  slack_api_url: {{ alertmanager_slack_webhook_url }}
{% endif %}

route:
  # Default receiver when no per-severity match — set conservatively
  # to PagerDuty so unrouted alerts still land somewhere visible.
  receiver: 'pagerduty-default'
  group_by: ['alertname', 'severity']
  group_wait: 30s
  group_interval: 5m
  repeat_interval: 12h
  routes:
    - matchers:
        - severity = "critical"
      receiver: 'pagerduty-default'
    - matchers:
        - severity = "warning"
      receiver: 'slack-default'
    - matchers:
        - severity = "info"
      receiver: 'slack-default'

receivers:
  - name: 'pagerduty-default'
{% if alertmanager_pagerduty_key %}
    pagerduty_configs:
      - service_key: {{ alertmanager_pagerduty_key }}
        send_resolved: true
{% else %}
    # No pagerduty_key set — alerts accumulate in the AlertManager
    # UI but don't fan out. Set alertmanager_pagerduty_key in vault
    # to enable PagerDuty integration.
{% endif %}

  - name: 'slack-default'
{% if alertmanager_slack_webhook_url %}
    slack_configs:
      - channel: {{ alertmanager_slack_channel }}
        send_resolved: true
        title: '{{ "{{" }} .GroupLabels.alertname {{ "}}" }}'
        text: |
          {{ "{{" }} range .Alerts {{ "}}" }}
          *{{ "{{" }} .Labels.severity | toUpper {{ "}}" }}* {{ "{{" }} .Annotations.summary {{ "}}" }}
          {{ "{{" }} .Annotations.description {{ "}}" }}
          {{ "{{" }} if .Annotations.runbook_url {{ "}}" }}runbook: {{ "{{" }} .Annotations.runbook_url {{ "}}" }}{{ "{{" }} end {{ "}}" }}
          {{ "{{" }} end {{ "}}" }}
{% else %}
    # No slack_webhook_url set — no fanout.
{% endif %}

inhibit_rules:
  # If a critical-severity alert fires for the same service, mute
  # warnings + info for that alertname to avoid stacking.
  - source_matchers:
      - severity = "critical"
    target_matchers:
      - severity =~ "warning|info"
    equal: ['alertname', 'service']
