# Galexie config — renders from defaults/main.yml + inventory.
# Schema matches config/config.example.toml in the stellar-galexie
# source tree (fetched at galexie-v26.0.0). If galexie's config
# schema changes, cross-reference this file against that example.

# HTTP port for galexie's own metrics / admin endpoint (bound loopback).
admin_port = {{ galexie_admin_port }}

# ──── Datastore — where exported ledger meta lands ─────────────────
[datastore_config]
type = "S3"

[datastore_config.params]
# S3-compatible storage (MinIO in our layout). Access + secret keys
# come from AWS_* env vars in /etc/default/galexie.
destination_bucket_path = "{{ galexie_s3_bucket }}/"
region                  = "{{ galexie_s3_region }}"
endpoint_url            = "{{ galexie_s3_endpoint }}"

[datastore_config.schema]
ledgers_per_file     = {{ galexie_ledgers_per_file }}
files_per_partition  = {{ galexie_files_per_partition }}

# ──── Stellar-core — embedded captive core for ledger replay ───────
[stellar_core_config]
# network=pubnet|testnet triggers galexie's built-in defaults
# (quorum + history archives). We also set captive_core_toml_path
# so our own 7-org tier-1 quorum is used instead of the built-in one,
# keeping this consistent with the primary stellar-core + stellar-rpc.
network                  = "{{ stellar_network }}"
captive_core_toml_path   = "/etc/stellar/captive-core-galexie.cfg"
stellar_core_binary_path = "/usr/bin/stellar-core"
