# Rendered by Ansible. Do not edit by hand — regenerate via
# `ansible-playbook ... --tags stellarindex`.
#
# EnvironmentFile for the stellarindex-{indexer,aggregator,api}
# systemd units (loaded as /etc/default/stellarindex). Carries the
# runtime secrets that /etc/stellarindex.toml deliberately omits:
#   - the Postgres DSN (with password)
#   - the MinIO read creds for the galexie buckets
#   - the AWS_* creds the indexer's S3 client uses for the
#     galexie-archive read path
#   - the off-chain connector API keys
#
# Secret values come from the ansible-vault inventory
# (inventory/r1.secrets.yml). Mode 0640, owner root.

# Postgres — overrides storage.postgres_dsn in stellarindex.toml so
# the password never lands in the world-readable on-disk config.
STELLARINDEX_POSTGRES_DSN=postgres://{{ postgres_user_stellarindex }}:{{ postgres_pass_stellarindex }}@127.0.0.1:5432/{{ postgres_db_stellarindex }}?sslmode=disable

# MinIO read creds for the galexie-live + galexie-archive buckets.
# Referenced by storage.s3_access_key_env / s3_secret_key_env in
# stellarindex.toml.
STELLARINDEX_S3_ACCESS_KEY={{ stellarindex_reader_access_key }}
STELLARINDEX_S3_SECRET_KEY={{ vault_stellarindex_reader_secret_key }}

# AWS_* — the indexer's S3 client reads these for the
# galexie-archive cold-read path. On r1 they point at local MinIO;
# a region reading from a remote archive overrides AWS_ENDPOINT_URL.
AWS_ACCESS_KEY_ID={{ stellarindex_reader_access_key }}
AWS_SECRET_ACCESS_KEY={{ vault_stellarindex_reader_secret_key }}
AWS_REGION={{ region_id }}
AWS_ENDPOINT_URL={{ galexie_s3_endpoint }}

# Off-chain connector API keys (external.* sources). Empty in the
# vault when a connector runs on its free tier.
MASSIVE_API_KEY={{ vault_massive_api_key | default('') }}
COINGECKO_DEMO_API_KEY={{ vault_coingecko_demo_api_key | default('') }}

# Chainlink divergence RPC URL. The Alchemy URL embeds its API key
# in the path, so it is treated as a secret and injected here
# rather than written into divergence.chainlink.rpc_url.
CHAINLINK_RPC_URL={{ vault_chainlink_rpc_url | default('') }}

# Resend transactional email (dashboard login links/codes). Hand-added
# 2026-06-18 (rc.110); codified 2026-07-03 — a render without it broke
# every login email.
STELLARINDEX_RESEND_API_KEY={{ vault_resend_api_key | default('') }}

# ClickHouse serving-query isolation (ADR-0048 D4). Overrides
# storage.clickhouse_serving_password_env's referenced var — the
# api_serving CH user's plaintext password, matching
# stellarindex.toml.j2's clickhouse_serving_user. Empty when
# stellarindex_clickhouse_serving_enabled is false (the pre-D4
# default); harmless either way since an empty
# clickhouse_serving_user means the API doesn't attempt to
# authenticate with it.
STELLARINDEX_CLICKHOUSE_SERVING_PASSWORD={{ clickhouse_serving_password | default('') }}
