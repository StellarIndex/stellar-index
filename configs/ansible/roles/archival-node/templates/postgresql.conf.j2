#
# postgresql.conf — tuned for stellar-core BucketListDB workload.
# See docs/architecture/infrastructure/archival-node-spec.md §3.2.
#

data_directory            = '/var/lib/postgresql/{{ postgres_version }}/main'
hba_file                  = '/etc/postgresql/{{ postgres_version }}/main/pg_hba.conf'
ident_file                = '/etc/postgresql/{{ postgres_version }}/main/pg_ident.conf'
external_pid_file         = '/var/run/postgresql/{{ postgres_version }}-main.pid'

listen_addresses          = '{{ postgres_listen_addresses }}'
port                      = {{ postgres_port }}
max_connections           = {{ postgres_max_connections }}
unix_socket_directories   = '/var/run/postgresql'

# Per-tx lock table sizing. Postgres sizes its lock table as
# `max_locks_per_transaction × max_connections`. TimescaleDB's
# chunk-based storage takes one shared-memory lock per chunk a
# query touches — not just INSERTs: any broad SELECT over a
# many-chunk hypertable (per-source coverage, pools/markets CTE,
# cagg/fx coverage) locks one entry per scanned chunk. Under
# concurrent load this saturates the table; writes/reads fail
# with SQLSTATE 53200 ("out of shared memory"). Two incidents:
#   - 2026-05-06 SEV-3 (default 64): ~1% of trades dropped, bumped
#     to 256 by hand
#     (`internal/incidents/data/2026-05-06-postgres-lock-table-full.md`).
#   - 2026-05-15 (256): trades grew to ~2,738 chunks; the all-time
#     SDEX backfill + concurrent diagnostic queries thrashed the
#     table again (single query observed holding 26,927 locks).
#     Re-sized to 4096 with permanent growth headroom — see the
#     long-form rationale on postgres_max_locks_per_transaction in
#     the role's defaults/main.yml.
# Codified here so a from-scratch R1 rebuild or R2/R3 cutover
# inherits the sizing automatically.
max_locks_per_transaction = {{ postgres_max_locks_per_transaction | default(4096) }}

# ─── Memory (~25% shared_buffers, ~50% effective_cache_size) ────────
shared_buffers            = {{ postgres_shared_buffers }}
effective_cache_size      = {{ postgres_effective_cache_size }}
work_mem                  = {{ postgres_work_mem }}
maintenance_work_mem      = {{ postgres_maintenance_work_mem }}

# ─── WAL ────────────────────────────────────────────────────────────
wal_level                 = replica
max_wal_senders           = 10
max_replication_slots     = 10
wal_compression           = {{ postgres_wal_compression }}
synchronous_commit        = on
checkpoint_timeout        = 15min
checkpoint_completion_target = 0.9
# WAL sizing matches r1's live config (postgresql.auto.conf ALTER
# SYSTEM overrides). 2GB/512MB is comfortable for the ingest +
# CAGG-refresh write profile; a from-scratch rebuild inherits the
# running values directly rather than the larger 8GB/2GB defaults.
max_wal_size              = 2GB
min_wal_size              = 512MB

# ─── Planner ────────────────────────────────────────────────────────
random_page_cost          = 1.1     # NVMe
effective_io_concurrency  = 200
default_statistics_target = 100

# ─── Logging ────────────────────────────────────────────────────────
log_destination           = 'stderr'
logging_collector         = on
log_directory             = '/var/log/postgresql'
log_filename              = 'postgresql-{{ postgres_version }}-main.log'
log_min_duration_statement = 1000
log_checkpoints           = on
log_connections           = on
log_disconnections        = on
log_lock_waits            = on
log_timezone              = 'UTC'

# ─── Locale / timezone ──────────────────────────────────────────────
datestyle                 = 'iso, mdy'
timezone                  = 'UTC'
lc_messages               = 'en_US.UTF-8'
lc_monetary               = 'en_US.UTF-8'
lc_numeric                = 'en_US.UTF-8'
lc_time                   = 'en_US.UTF-8'
default_text_search_config = 'pg_catalog.english'

# ─── Stats ──────────────────────────────────────────────────────────
# `timescaledb` MUST be preloaded — the trades/oracle_updates
# hypertables, continuous aggregates and Timescale background jobs
# all depend on the extension being available at startup. Matches
# r1's live config; a rebuild without it breaks every CAGG.
shared_preload_libraries  = 'timescaledb,pg_stat_statements'
