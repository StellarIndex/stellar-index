# stellar-rpc config.
# SQLite path on the ZFS rpc dataset (recordsize=16K).
# Event retention capped to keep SQLite bounded.

ENDPOINT                   = "0.0.0.0:{{ stellar_rpc_port }}"
ADMIN_ENDPOINT             = "127.0.0.1:{{ stellar_rpc_admin_port }}"

NETWORK_PASSPHRASE         = "{% if stellar_network == 'pubnet' %}Public Global Stellar Network ; September 2015{% elif stellar_network == 'testnet' %}Test SDF Network ; September 2015{% else %}{{ stellar_network }}{% endif %}"

# Captive-core's config is a STRICT SUBSET of stellar-core's — it
# rejects NODE_IS_VALIDATOR, NODE_HOME_DOMAIN, CATCHUP_*, HTTP_PORT,
# PEER_PORT, DATABASE (those are driven by stellar-rpc itself).
# We render it as a separate file from the same Jinja template in
# "captive" mode.
CAPTIVE_CORE_CONFIG_PATH   = "/etc/stellar/captive-core.cfg"
STELLAR_CORE_BINARY_PATH   = "/usr/bin/stellar-core"
CAPTIVE_CORE_STORAGE_PATH  = "/var/lib/stellar-rpc/captive"

# Disable captive-core's HTTP server. Default is 11626 which is
# taken by the primary stellar-core on this box. captive-core.cfg
# also has HTTP_PORT=0; captive-core validates the parent's value
# against the config's, so both must agree. 0 = don't bind.
STELLAR_CAPTIVE_CORE_HTTP_PORT = 0

DB_PATH                    = "/var/lib/stellar-rpc/rpc.sqlite"

# Retention — see archival-node-spec.md §3.3.1
HISTORY_RETENTION_WINDOW   = {{ stellar_rpc_event_retention_ledgers }}
TRANSACTION_RETENTION_WINDOW = {{ stellar_rpc_tx_retention_ledgers }}

# HISTORY_ARCHIVE_URLS must match at least one archive in stellar-core.cfg
HISTORY_ARCHIVE_URLS = [
    "https://history.stellar.org/prd/core-live/core_live_001",
    "https://history.stellar.org/prd/core-live/core_live_002",
    "https://history.stellar.org/prd/core-live/core_live_003",
]
