#!/usr/sbin/nft -f
#
# Stellar Index archival-node firewall.
#
# Policy: default-deny on input; SCP peer + SSH open publicly;
# internal-only services restricted to internal_cidrs.

flush ruleset

table inet filter {

  # ─── Sets of trusted CIDRs ─────────────────────────────────────
  set internal_v4 {
    type ipv4_addr
    flags interval
    elements = {
{% for cidr in internal_cidrs if ':' not in cidr %}
      {{ cidr }}{% if not loop.last %},{% endif %}
{% endfor %}
    }
  }

  set ssh_allowed_v4 {
    type ipv4_addr
    flags interval
    elements = {
{% for cidr in allowed_ssh_cidrs if ':' not in cidr %}
      {{ cidr }}{% if not loop.last %},{% endif %}
{% endfor %}
    }
  }

  # ─── Input chain ───────────────────────────────────────────────
  chain input {
    type filter hook input priority filter; policy drop;

    # Conntrack
    ct state established,related accept
    ct state invalid drop

    # Loopback
    iif lo accept

    # ICMP — ping/traceroute OK, rate-limited
    ip protocol icmp limit rate 10/second accept
    ip6 nexthdr ipv6-icmp limit rate 10/second accept

    # SSH — only from allowed CIDRs, rate-limited.
    # F-1201 follow-up (codex audit-2026-05-12): 30/minute (was
    # 4/minute) is tight enough to throttle brute-force scanners
    # but loose enough that operator multi-shell sessions over
    # SSH multiplexing don't accidentally lock themselves out
    # (verified on r1: a /loop session hammering SSH at ~10/min
    # hit the old 4/min cap mid-deploy).
{% for rule in public_allow_ports if rule.port == 22 %}
    tcp dport {{ rule.port }} ip saddr @ssh_allowed_v4 ct state new limit rate 30/minute accept comment "{{ rule.comment }}"
{% endfor %}

    # Public ports (stellar-core SCP peer)
{% for rule in public_allow_ports if rule.port != 22 %}
    {{ rule.proto }} dport {{ rule.port }} accept comment "{{ rule.comment }}"
{% endfor %}

    # Internal-only services
{% for rule in internal_allow_ports %}
    {{ rule.proto }} dport {{ rule.port }} ip saddr @internal_v4 accept comment "{{ rule.comment }}"
{% endfor %}

    # Log drops at low rate for debugging
    limit rate 5/second log prefix "nft-drop: " level info
  }

  # ─── Forward + output ──────────────────────────────────────────
  chain forward {
    type filter hook forward priority filter; policy drop;
  }

  chain output {
    type filter hook output priority filter; policy accept;
  }
}
