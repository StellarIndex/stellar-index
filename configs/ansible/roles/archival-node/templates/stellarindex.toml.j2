# Rendered by Ansible. Do not edit by hand — regenerate via
# `ansible-playbook ... --tags stellarindex`.
#
# Contains everything except secrets. The Postgres password, the
# MinIO read creds and the off-chain connector API keys are
# injected at runtime via /etc/default/stellarindex (sourced by the
# systemd units' EnvironmentFile, overriding any DSN here).
#
# This config is region-INVARIANT by design except for the handful
# of values templated below: the closed-bucket API contract
# (ADR-0015) requires all regions to produce byte-equivalent
# aggregate output from the same input, so the source list /
# aggregator / oracle / external / supply blocks are identical
# across r1/r2/r3. Per-region knobs: region identity, S3
# endpoints/region/buckets, and backfill_from_ledger (each
# region's own galexie seam — see ADR-0016).

[region]
id   = "{{ region_id }}"
name = "{{ region_name }}"
home_domain = "{{ home_domain }}"

[stellar]
network             = "{{ stellar_network }}"
core_http_endpoint  = "http://127.0.0.1:11626"
rpc_endpoints       = ["http://127.0.0.1:8000"]
history_archive_url = "https://history.stellar.org/prd/core-live/core_live_001"

[storage]
postgres_dsn       = "postgres://{{ postgres_user_stellarindex }}@127.0.0.1:5432/{{ postgres_db_stellarindex }}?sslmode=disable"
redis_addr         = "127.0.0.1:6379"
s3_endpoint        = "{{ galexie_s3_endpoint }}"
s3_region          = "{{ region_id }}"
s3_bucket_archive  = "{{ galexie_s3_bucket_archive | default('galexie-archive') }}"
s3_bucket_live     = "{{ galexie_s3_bucket | default('galexie-live') }}"

# Cold-tier (ADR-0027). aws-public-blockchain Open Data Sponsorship.
s3_cold_endpoint        = "{{ stellarindex_s3_cold_endpoint | default('') }}"
s3_cold_region          = "{{ stellarindex_s3_cold_region | default('') }}"
s3_cold_bucket_archive  = "{{ stellarindex_s3_cold_bucket_archive | default('') }}"
s3_cold_access_key_env  = "{{ stellarindex_s3_cold_access_key_env | default('') }}"
s3_cold_secret_key_env  = "{{ stellarindex_s3_cold_secret_key_env | default('') }}"
s3_access_key_env  = "STELLARINDEX_S3_ACCESS_KEY"
s3_secret_key_env  = "STELLARINDEX_S3_SECRET_KEY"

# ClickHouse raw lake (ADR-0034) + dual-sink durability (ADR-0041,
# defaults TRUE since v0.7.0). The template predated the pivot — a
# render without these silently degraded the indexer to Postgres-only
# (2026-07-03 drift audit).
clickhouse_addr             = "{{ stellarindex_clickhouse_addr | default('127.0.0.1:9300') }}"
clickhouse_live_sink        = {{ stellarindex_clickhouse_live_sink | default(true) | to_json }}
clickhouse_projector_source = {{ stellarindex_clickhouse_projector_source | default(true) | to_json }}

# ClickHouse serving-query isolation (ADR-0048 D4). Empty (the
# stellarindex_clickhouse_serving_enabled default) preserves the
# pre-D4 behavior byte-for-byte: the API's explorer/supply readers
# authenticate as CH's unauthenticated `default` user, same as every
# other CH connection this repo makes. Set
# stellarindex_clickhouse_serving_enabled: true in inventory ONLY
# after 20-clickhouse-serving-profile.yml has provisioned the CH-side
# `api_serving` user (a separate, coordinated apply — see that task
# file's header) — flipping this on first would point the API at a
# CH user that doesn't exist yet and 503 every serving read.
# clickhouse_serving_password (the secret half) is injected via
# STELLARINDEX_CLICKHOUSE_SERVING_PASSWORD in stellarindex.env.j2,
# never written here.
clickhouse_serving_user = "{{ clickhouse_serving_user if (stellarindex_clickhouse_serving_enabled | default(false)) else '' }}"

[ingestion]
enabled_sources       = {{ stellarindex_enabled_sources | to_json }}
backfill_from_ledger  = {{ stellarindex_backfill_from_ledger | int }}

[ingestion.projector]
# ADR-0031/0032 one-writer projector — enabled everywhere since rc.97.
enabled            = true
persist_per_source = true

[oracle.reflector]
