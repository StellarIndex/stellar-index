# vault_chainlink_rpc_url carries the keyed Alchemy endpoint; the
# llamarpc fallback is Cloudflare-challenged since 2026-06 (rc.138 fix).
rpc_url = "{{ vault_chainlink_rpc_url | default('https://eth.llamarpc.com') }}"

[divergence.chainlink.feeds]

