[oracle.soroswap]
factory_contract  = "CA4HEQTL2WPEUYKYKCDOHCDNIV4QHNJ7EL4J4NQ6VADP7SYHVRYZ7AW2"
seed_rpc_endpoint = "https://mainnet.sorobanrpc.com"

# ──────────────────────────────────────────────────────────────────
# Aggregator + trades — added 2026-05-04 to fix the headline-product
# 404. Pre-fix: vwap_writes_total stuck at 0, /v1/price?asset=native
# &quote=fiat:USD returned 404 because the aggregator was querying
# XLM/fiat:USD verbatim (no abstract trades) and the dominant XLM/USD
# volume on Stellar is quoted in classic Circle USDC, which is
# intentionally not in the abstract stablecoin map. Per PR #629 the
# aggregator now reads usd_pegged_classic_assets from this config
# and appends classic source pairs to USD-target expansions.
# ──────────────────────────────────────────────────────────────────
[aggregate]
enable_stablecoin_fiat_proxy = true
min_usd_volume = 10000  # per-pair USD-volume floor for VWAP publication (anti-manipulation + confidence). Re-enabled 2026-07-01: the CEX connectors landed and flow live volume (binance/coinbase/kraken/bitstamp, millions of trades), so fiat:USD pairs clear $10k/window easily while thin/manipulable pairs are gated. (Was 0 during the on-chain-only bootstrap.)

[trades]
usd_pegged_classic_assets = [
  "USDC-GA5ZSEJYB37JRC5AVCIA5MOP4RHTM335X2KGX3IHOJAPP5RE34K4KZVN",
]

# ──────────────────────────────────────────────────────────────────
# External — off-chain CEX/FX/aggregator connectors.
# Added 2026-05-05 to close the crypto:XLM/fiat:USD 404 + provide
# CEX coverage. Free venues only on r1 today (no API
# keys provisioned for the paid FX/aggregator tier).
# ──────────────────────────────────────────────────────────────────
[external]

  [external.binance]
  enabled = true

  [external.kraken]
  enabled = true

  [external.bitstamp]
  enabled = true

  [external.coinbase]
  enabled = true

  [external.coingecko]
  enabled = true

  [external.ecb]
  enabled = true

  [external.chainlink]
  enabled = true
  poll_interval = "30s"
  # rpc_url is set via CHAINLINK_RPC_URL env in /etc/default/stellarindex
  # (Alchemy URL embeds the API key in the path -- treat as secret).
  # Empty feed_map falls back to internal/sources/external/chainlink/defaults.go
  # (BTC/ETH/LINK/EUR/GBP/JPY vs USD on Ethereum mainnet AggregatorV3 proxies).
  [external.chainlink.feed_map]

# ──────────────────────────────────────────────────────────────────
# API — added 2026-05-05 to trust the Caddy loopback proxy.
# Caddy listens on :80 + :443, terminates TLS, proxies to localhost:3000
# with X-Forwarded-{For,Proto,Host} set. Trusting 127.0.0.1/32 makes
# the API honour those headers (so request logs show the real client IP
# instead of 127.0.0.1, and rate-limiting buckets per real client).
# Listen-addr stays 0.0.0.0:3000 — Caddy is the public surface, but
# direct access via :3000 still works for stellarindex-sla-probe and
# ad-hoc operator curl.
# ──────────────────────────────────────────────────────────────────
[api]
listen_addr = "127.0.0.1:3000"
allowed_origins = ["https://stellarindex.io", "https://api.stellarindex.io", "https://status.stellarindex.io", "https://docs.stellarindex.io", "https://dashboard.stellarindex.io", "https://www.stellarindex.io"]
allow_credentials = true
# AC7 onboarding fix (2026-06-13): verification-gated signup stays OFF
# until a verified-sender domain is set up end-to-end.
signup_require_email_verification = false

auth_mode = "apikey_optional"
trusted_proxy_cidrs = ["127.0.0.1/32"]
prometheus_url = "http://localhost:9090"
anon_rate_limit_per_min = 6000
key_rate_limit_per_min = 6000

# ──────────────────────────────────────────────────────────────────
# [supply] — operator-curated registries.
# Added 2026-05-07: SAC wrapper resolution map. Sources verified
# via api.stellar.expert/explorer/public/contract/<C-strkey>.
# Drives:
#   - /v1/sac-wrappers wire endpoint (rc.27+)
#   - SAC-balance observer's watched-contract filter
#   - aggregator's USD-volume computation for Soroban DEX trades
#     (Soroswap/Phoenix/Aquarius/Comet emit C-strkeys at the wire,
#     not the underlying CODE-ISSUER classic asset key).

# F-1266 (audit-2026-05-12): F2 fields on /v1/assets were NULL
# because watched_classic_assets was unset. Populated with the
# Stellar-native verified currencies mirroring
# internal/currency/data/seed.yaml. Next aggregator restart
# starts populating market_cap_usd / fdv_usd / circulating_supply
# / total_supply / max_supply for these.
[api.dashboard]
base_url           = "{{ stellarindex_dashboard_base_url | default('https://stellarindex.io') }}"
email_from         = "{{ stellarindex_dashboard_email_from | default('Stellar Index <hello@stellarindex.io>') }}"
resend_api_key_env = "STELLARINDEX_RESEND_API_KEY"
cookie_secure      = true
cookie_domain      = "{{ stellarindex_dashboard_cookie_domain | default('.stellarindex.io') }}"

[supply]
# aggregator_refresh_enabled starts the supply-refresh goroutine
# path (2026-05-14). It emits the success metric even when no rows
# match (no_metadata basis); without it
# stellarindex_aggregator_supply_refresh_never_initialized fires
# permanently. Cadence default = 5m.
aggregator_refresh_enabled = true
aggregator_refresh_cadence = "5m"
watched_classic_assets = [
{% for asset in stellarindex_watched_classic_assets | default([
