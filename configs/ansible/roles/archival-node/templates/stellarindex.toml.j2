# ──────────────────────────────────────────────────────────────────
# [divergence.chainlink] — added 2026-05-08. HTTP cross-check
# against Chainlink mainnet feeds. Fetches AggregatorV3.latestAnswer
# via Cloudflare's public ETH RPC. Off-chain reference only — does
# not contribute to VWAP. Pair format mirrors canonical.Pair.String().
[divergence.chainlink]
