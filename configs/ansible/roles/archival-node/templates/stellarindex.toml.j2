  decimals = 8

# 2026-05-14 — Phase 2 freeze stop-gap.
# crypto:BTC/fiat:EUR has source_count=1 structurally (only one
# CEX publishes BTC/EUR). Phase 2 fires every bucket because the
# 3-signal AND (low confidence + high z + low source_count) is
# always satisfied. stellarindex_anomaly_freeze_sustained was
# page-firing for hours with no customer impact (FreezeWriter is
# nil; counter increments but no Redis marker is written). z=100
# is effectively-disabled — real anomalies (z > 100) are
# physically impossible without a market move that would also
# trigger Phase 1. Revisit once baselines mature post-backfill.
[anomaly.phase2]
z_score_min_freeze = 100
